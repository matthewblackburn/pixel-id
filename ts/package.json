{
  "name": "pixel-id",
  "version": "0.1.0",
  "description": "Deterministic pixel avatar rendering from snowflake IDs — powered by Go compiled to WASM for guaranteed cross-platform parity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/matthewblackburn/pixel-id"
  },
  "keywords": ["avatar", "pixel", "snowflake", "id", "wasm", "deterministic"],
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react/index.js",
      "types": "./dist/react/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/wasm_exec.js dist/wasm_exec.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "jsdom": "^29.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
